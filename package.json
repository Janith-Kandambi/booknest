{
  "name": "booknest-monorepo",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev -w @booknest/client",
    "dev:server": "npm run dev -w @booknest/server",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "start": "npm run start -w @booknest/server"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
